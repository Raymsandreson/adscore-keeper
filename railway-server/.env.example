# Copie este arquivo como .env e preencha os valores

# Porta do servidor (Railway define automaticamente via $PORT)
PORT=3000

# Chave de API para autenticar chamadas do frontend
RAILWAY_API_KEY=gerar-uma-chave-segura-aqui

# Supabase Externo (banco de dados principal — WhatsJUD)
EXTERNAL_SUPABASE_URL=https://seu-projeto.supabase.co
EXTERNAL_SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Lovable Cloud (para chamar funções de IA que permanecem no Cloud)
CLOUD_FUNCTIONS_URL=https://gliigkupoebmlbwyvijp.supabase.co
CLOUD_ANON_KEY=sua-anon-key-do-lovable-cloud
CLOUD_SERVICE_ROLE_KEY=sua-service-role-key-do-lovable-cloud

# APIs de terceiros
GOOGLE_AI_API_KEY=
ELEVENLABS_API_KEY=
